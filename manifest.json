{
  "manifest_version": 3,

  "name": "Clean Links",

  "version": "1.3",

  "description": "Removes tracking junk from URLs",

  "permissions": [
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png"
    },

    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],

      "js": [
        "cleaner.js"
      ],

      "run_at": "document_start"
    }
  ]
}